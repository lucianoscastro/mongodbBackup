# --- MongoDB (obrigatório) ---
# Cluster de origem. Todas as bases são incluídas, exceto as de EXCLUDE_DBS.
MONGO_URI=mongodb://user:pass@host:27017/?authSource=admin

# --- Agendamento e retenção local ---
INTERVAL_HOURS=6          # aceita fração: 0.5 = 30 min
MAX_BACKUPS=3             # arquivos mantidos por base no disco local
RETRY_MINUTES=15          # espera após um ciclo que falhou
RUN_ON_START=true         # faz um backup ao subir o container
DUMP_TIMEOUT_MINUTES=60   # aborta o dump travado; aumente se as bases forem grandes
BACKUP_DIR=/backups
EXCLUDE_DBS=admin config local

# --- Offsite (S3) ---
# S3_ENABLED=false mantém só o backup local.
S3_ENABLED=false
S3_BUCKET=
S3_PREFIX=mongo
S3_REGION=us-east-1
# S3_ENDPOINT só para S3-compatíveis (MinIO, Cloudflare R2). Vazio = AWS.
S3_ENDPOINT=

# Recomendado: credencial restrita a s3:PutObject no prefixo.
# Assim quem invadir o servidor não consegue ler nem apagar os backups —
# mas o restore --from-s3 vai exigir outra credencial, com GetObject/ListBucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
