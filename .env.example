# Um engine é habilitado quando suas variáveis obrigatórias estão definidas.
# Configure um, outro ou os dois.

# --- MongoDB ---
# Cluster de origem. Todas as bases são incluídas, exceto as de EXCLUDE_DBS.
MONGO_URI=mongodb://user:pass@host:27017/?authSource=admin
EXCLUDE_DBS=admin config local
DUMP_TIMEOUT_MINUTES=60   # aborta o mongodump travado; aumente se as bases forem grandes

# --- SQL Server ---
# O BACKUP do SQL Server é server-side: monte o diretório de backup do servidor
# também neste container (ver README). MSSQL_DIR_SERVER = caminho que o SQL
# Server vê; MSSQL_DIR_LOCAL = o mesmo volume, visto por este container.
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=
MSSQL_DATABASES=          # vazio = todas as bases de usuário
MSSQL_EXCLUDE_DBS=
MSSQL_DIR_SERVER=/var/opt/mssql/backup
MSSQL_DIR_LOCAL=/mssql-backup
MSSQL_COMPRESS=false      # true exige edição com COMPRESSION (não Express)
MSSQL_TIMEOUT_MINUTES=60

# --- UI web (modo serve, padrão) ---
# Obrigatória no modo serve (mínimo 8 caracteres). Sem UI? Rode o container
# com o comando "daemon" e nenhuma porta exposta.
ADMIN_PASSWORD=
ADMIN_USER=admin
WEB_PORT=8080
SESSION_TTL_HOURS=12
# SESSION_SECRET fixo mantém o login entre restarts do container (opcional).
SESSION_SECRET=
# auto = cookie Secure quando atrás de HTTPS (TLS direto ou X-Forwarded-Proto).
COOKIE_SECURE=auto
# Defina se o login der "origem inválida" atrás de um reverse proxy (Cloudflare,
# nginx, Traefik...) que não repassa o Host original intacto para o container.
# Ex.: PUBLIC_URL=https://backup.exemplo.com
PUBLIC_URL=

# --- Agendamento e retenção local ---
INTERVAL_HOURS=6          # aceita fração: 0.5 = 30 min
MAX_BACKUPS=3             # arquivos mantidos por base no disco local
RETRY_MINUTES=15          # espera após um ciclo que falhou
RUN_ON_START=true         # faz um backup ao subir o container
BACKUP_DIR=/backups

# --- Offsite (S3) ---
# S3_ENABLED=false mantém só o backup local.
S3_ENABLED=false
S3_BUCKET=
# Keys: <prefix>/<engine>/<base>/<arquivo>. Prefixo vazio (padrão) preserva o
# layout da imagem antiga mongo-only: mongo/<base>/<arquivo>.
S3_PREFIX=
S3_REGION=us-east-1
# S3_ENDPOINT só para S3-compatíveis (MinIO, Cloudflare R2). Vazio = AWS.
S3_ENDPOINT=

# Recomendado: credencial restrita a s3:PutObject no prefixo.
# Assim quem invadir o servidor não consegue ler nem apagar os backups —
# mas o restore --from-s3 vai exigir outra credencial, com GetObject/ListBucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
